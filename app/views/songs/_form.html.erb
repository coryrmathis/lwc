<%= form_with model: song, class: "needs-validation" do |f| %>
  <% if song.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% song.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3 mb-3">
    <div class="col-12">
      <%= f.label :title, class: "form-label" %>
      <%= f.text_field :title, class: "form-control", required: true %>
    </div>

    <div class="col-md-4">
      <%= f.label :status, class: "form-label" %>
      <%= f.select :status, Song.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "form-select" %>
    </div>

    <div class="col-md-4">
      <%= f.label :key, "Key", class: "form-label" %>
      <%= f.text_field :key, class: "form-control", placeholder: "e.g. G, Bm, Eb" %>
    </div>

    <div class="col-md-2">
      <%= f.label :bpm, "BPM", class: "form-label" %>
      <%= f.number_field :bpm, class: "form-control", min: 1 %>
    </div>

    <div class="col-md-2">
      <%= f.label :length_seconds, "Length (sec)", class: "form-label" %>
      <%= f.number_field :length_seconds, class: "form-control", min: 0 %>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-12">
      <div class="form-check">
        <%= f.check_box :is_cover, class: "form-check-input" %>
        <%= f.label :is_cover, "This is a cover", class: "form-check-label" %>
      </div>
    </div>

    <div class="col-md-6">
      <%= f.label :original_artist, class: "form-label" %>
      <%= f.text_field :original_artist, class: "form-control", placeholder: "Original artist (if cover)" %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :lyrics, class: "form-label" %>
    <%= f.text_area :lyrics, class: "form-control", rows: 10 %>
  </div>

  <div class="mb-4">
    <%= f.label :notes, class: "form-label" %>
    <%= f.text_area :notes, class: "form-control", rows: 3, placeholder: "Arrangement notes, cues, etc." %>
  </div>

  <div class="mb-4">
    <div class="d-flex justify-content-between align-items-end mb-1">
      <%= f.label :chord_chart, "Chord Chart", class: "form-label mb-0" %>
      <small>
        <a href="https://www.chordpro.org/chordpro/chordpro-cheat_sheet/" target="_blank" rel="noopener" class="text-muted">ChordPro syntax ↗</a>
      </small>
    </div>
    <%= f.text_area :chord_chart, class: "form-control font-monospace", rows: 15,
        placeholder: "{title: My Song}\n{key: G}\n{time: 4/4}\n\n{start_of_verse}\n[G] / / / | [C] / / / | [D] / / / | [G] / / /\n{end_of_verse}" %>
    <div class="form-text">Tip: run <code>/chord-chart</code> in Claude Code to generate ChordPro from a plain-language description, then paste it here.</div>
  </div>

  <%= f.submit class: "btn btn-primary" %>
  <%= link_to "Cancel", songs_path, class: "btn btn-link" %>
<% end %>
