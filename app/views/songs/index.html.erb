<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Songs</h1>
    <%= link_to "New Song", new_song_path, class: "btn btn-primary" %>
  </div>

  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% end %>

  <% if @songs.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Title</th>
          <th>Key</th>
          <th>BPM</th>
          <th>Length</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @songs.each do |song| %>
          <tr>
            <td>
              <%= link_to song.title, song %>
              <% if song.is_cover? %>
                <span class="badge bg-secondary ms-1">Cover</span>
              <% end %>
            </td>
            <td><%= song.key %></td>
            <td><%= song.bpm %></td>
            <td><%= song.length_display %></td>
            <td><span class="badge bg-<%= status_badge_class(song.status) %>"><%= song.status.humanize %></span></td>
            <td class="text-end">
              <%= link_to "Edit", edit_song_path(song), class: "btn btn-sm btn-outline-secondary" %>
              <%= button_to "Delete", song, method: :delete, class: "btn btn-sm btn-outline-danger ms-1", form: { data: { turbo_confirm: "Delete #{song.title}?" } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">No songs yet. <%= link_to "Add the first one.", new_song_path %></p>
  <% end %>
</div>
