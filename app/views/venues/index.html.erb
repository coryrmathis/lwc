<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Venues</h1>
    <%= link_to "New Venue", new_venue_path, class: "btn btn-primary" %>
  </div>

  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% end %>

  <% if @venues.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Name</th>
          <th>Location</th>
          <th>Contact</th>
          <th>Last Contacted</th>
          <th>Next Follow-up</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @venues.each do |venue| %>
          <tr>
            <td><%= link_to venue.name, venue %></td>
            <td><%= venue.location_display %></td>
            <td>
              <% if venue.contact_name.present? %>
                <%= venue.contact_name %>
                <% if venue.contact_email.present? %>
                  <br><small class="text-muted"><%= venue.contact_email %></small>
                <% end %>
              <% end %>
            </td>
            <td><%= venue.last_contacted_at&.strftime("%b %-d, %Y") %></td>
            <td><%= venue.next_follow_up_at&.strftime("%b %-d, %Y") %></td>
            <td class="text-end">
              <%= link_to "Edit", edit_venue_path(venue), class: "btn btn-sm btn-outline-secondary" %>
              <%= button_to "Delete", venue, method: :delete, class: "btn btn-sm btn-outline-danger ms-1", form: { data: { turbo_confirm: "Delete #{venue.name}?" } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">No venues yet. <%= link_to "Add the first one.", new_venue_path %></p>
  <% end %>
</div>
