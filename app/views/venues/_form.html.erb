<%= form_with model: venue, class: "needs-validation" do |f| %>
  <% if venue.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% venue.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <h6 class="text-muted text-uppercase mb-2 mt-3">Venue Info</h6>
  <div class="row g-3 mb-3">
    <div class="col-12">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>

    <div class="col-md-8">
      <%= f.label :website, class: "form-label" %>
      <%= f.url_field :website, class: "form-control", placeholder: "https://..." %>
    </div>
  </div>

  <h6 class="text-muted text-uppercase mb-2 mt-4">Location</h6>
  <div class="row g-3 mb-3">
    <div class="col-12">
      <%= f.label :address, class: "form-label" %>
      <%= f.text_field :address, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= f.label :city, class: "form-label" %>
      <%= f.text_field :city, class: "form-control" %>
    </div>

    <div class="col-md-3">
      <%= f.label :state, class: "form-label" %>
      <%= f.text_field :state, class: "form-control", placeholder: "TX" %>
    </div>
  </div>

  <h6 class="text-muted text-uppercase mb-2 mt-4">Contact</h6>
  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <%= f.label :contact_first_name, "First Name", class: "form-label" %>
      <%= f.text_field :contact_first_name, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= f.label :contact_last_name, "Last Name", class: "form-label" %>
      <%= f.text_field :contact_last_name, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= f.label :contact_email, "Email", class: "form-label" %>
      <%= f.email_field :contact_email, class: "form-control" %>
    </div>

    <div class="col-md-4">
      <%= f.label :phone, class: "form-label" %>
      <%= f.telephone_field :phone, class: "form-control" %>
    </div>
  </div>

  <h6 class="text-muted text-uppercase mb-2 mt-4">Outreach Tracking</h6>
  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <%= f.label :last_contacted_at, "Last Contacted", class: "form-label" %>
      <%= f.datetime_local_field :last_contacted_at, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= f.label :next_follow_up_at, "Next Follow-up", class: "form-label" %>
      <%= f.datetime_local_field :next_follow_up_at, class: "form-control" %>
    </div>
  </div>

  <h6 class="text-muted text-uppercase mb-2 mt-4">Notes</h6>
  <div class="mb-4">
    <%= f.text_area :notes, class: "form-control", rows: 4, placeholder: "Booking notes, vibe, capacity, parking, etc." %>
  </div>

  <%= f.submit class: "btn btn-primary" %>
  <%= link_to "Cancel", venues_path, class: "btn btn-link" %>
<% end %>
