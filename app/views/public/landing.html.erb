<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Band Links</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  
  <style>
    body {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    
    .linktree-container {
      max-width: 480px;
      margin: 0 auto;
      padding: 2rem 1rem;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    
    .profile-section {
      text-align: center;
      margin-bottom: 3rem;
    }
    
    .profile-image {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: white;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      box-shadow: 0 8px 32px rgba(255, 255, 255, 0.2);
      font-size: 3rem;
    }
    
    .profile-title {
      color: white;
      font-size: 1.8rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }
    
    .profile-subtitle {
      color: rgba(255, 255, 255, 0.8);
      font-size: 1rem;
      margin-bottom: 0;
    }
    
    .links-container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    
    .link-button {
      display: block;
      padding: 1rem 1.5rem;
      background: rgba(255, 255, 255, 0.95);
      color: #333;
      text-decoration: none;
      border-radius: 12px;
      font-weight: 500;
      text-align: center;
      transition: all 0.3s ease;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    }
    
    .link-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
      background: white;
      color: #333;
      text-decoration: none;
    }
    
    .link-button:active {
      transform: translateY(0);
    }
    
    .link-icon {
      margin-right: 0.75rem;
      font-size: 1.1em;
    }
    
    @media (max-width: 480px) {
      .linktree-container {
        padding: 1.5rem 1rem;
      }
      
      .profile-image {
        width: 100px;
        height: 100px;
        font-size: 2.5rem;
      }
      
      .profile-title {
        font-size: 1.6rem;
      }
      
      .link-button {
        padding: 0.9rem 1.2rem;
      }
    }
  </style>
</head>

<body>
  <div class="linktree-container">
    <div class="profile-section">
      <div class="profile-image">
        <%=image_tag("lwc-flutters.jpeg", size: "75x75")%>
      </div>
      <h1 class="profile-title">Lousy With Coyotes</h1>
      <p class="profile-subtitle">Rock • Alternative • Live Music</p>
    </div>
    
    <div class="links-container">
      <%= link_to "https://music.apple.com/us/artist/lousy-with-coyotes/1692258871", class: "link-button" do %>
        <span class="link-icon">🎵</span>
        Listen to Our Music
      <% end %>
      
      <%= link_to "https://www.instagram.com/lousywithcoyotes/", class: "link-button" do %>
        <span class="link-icon">📷</span>
        Instagram
      <% end %>
      
    </div>
  </div>
</body>
</html>